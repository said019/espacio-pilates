# ============================================================
# VALIANCE PILATES — Variables de Entorno
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env a git.
# ============================================================

# Backend API (URL base del backend en Railway una vez desplegado)
VITE_API_URL=https://<tu-backend>.up.railway.app/api

# URL pública de la app (usada en links de emails: reset password, magic links, etc.)
APP_URL=https://valiancepilates.com.mx

# URL base de assets públicos/email branding (si no se define, usa APP_URL)
SITE_URL=https://valiancepilates.com.mx

# Orígenes permitidos por CORS (separados por coma)
CORS_ALLOWED_ORIGINS=https://valiancepilates.com.mx,http://localhost:5173,http://127.0.0.1:5173

# Rate limiting API (opcional)
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=180
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=20

# Resend — API para envío de emails transaccionales
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Valiance Pilates <hola@valiancepilates.com.mx>

# Base de datos PostgreSQL (solo para scripts de migración locales, NO exponer en frontend)
DATABASE_URL=postgresql://postgres:<password>@<host>:<port>/railway

# Evolution API (WhatsApp) — proyecto separado en Railway
# Si se dejan vacías, todos los envíos de WhatsApp se omiten silenciosamente.
# Ver EVOLUTION-API-SETUP.md para instrucciones de despliegue.
EVOLUTION_API_URL=https://<tu-evolution-api>.up.railway.app
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=valiance-pilates
