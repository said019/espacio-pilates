# ============================================================
# VALIANCE PILATES — Variables de Entorno
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env a git.
# ============================================================

# Backend API (URL base del backend en Railway una vez desplegado)
VITE_API_URL=https://<tu-backend>.up.railway.app/api

# URL pública de la app (usada en links de emails: reset password, magic links, etc.)
APP_URL=https://valiancepilates.com.mx

# URL base de assets públicos/email branding (si no se define, usa APP_URL)
SITE_URL=https://valiancepilates.com.mx

# Orígenes permitidos por CORS (separados por coma)
CORS_ALLOWED_ORIGINS=https://valiancepilates.com.mx,http://localhost:5173,http://127.0.0.1:5173

# Rate limiting API (opcional)
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=180
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=20

# Resend — API para envío de emails transaccionales
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Valiance Pilates <hola@valiancepilates.com.mx>

# Base de datos PostgreSQL (solo para scripts de migración locales, NO exponer en frontend)
DATABASE_URL=postgresql://postgres:<password>@<host>:<port>/railway

# Evolution API (WhatsApp) — proyecto separado en Railway
# Si se dejan vacías, todos los envíos de WhatsApp se omiten silenciosamente.
# Ver EVOLUTION-API-SETUP.md para instrucciones de despliegue.
EVOLUTION_API_URL=https://<tu-evolution-api>.up.railway.app
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=valiance-pilates

# ============================================================
# MercadoPago (Checkout Pro) — pagos con tarjeta
# ============================================================
# Access Token de PRODUCCIÓN (APP_USR-...). Si se deja vacío, la opción
# "Tarjeta" se oculta en el checkout y no se generan preferencias.
MP_ACCESS_TOKEN=
# Clave secreta del webhook (panel MP → Webhooks). Si se deja vacía, se omite
# la verificación de firma (NO recomendado en producción).
MP_WEBHOOK_SECRET=
# URL pública del backend (para notification_url del webhook).
BACKEND_URL=https://web-production-b1a1d.up.railway.app
# URL pública del frontend (para back_urls de retorno).
FRONTEND_URL=https://frontend-production-dcb15.up.railway.app

# ============================================================
# Web Push (VAPID) — notificaciones push a la PWA. Ya configurado en producción.
# ============================================================
# Generar una vez con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:espaciopilatesvm@gmail.com

# ============================================================
# Apple Wallet (.pkpass nativo firmado). Si faltan certs → modo "web pass" (HTML).
# Los PEM multilinea van cómodos en Railway como *_BASE64 (base64 -i archivo.pem).
# ============================================================
APPLE_TEAM_ID=
APPLE_PASS_TYPE_ID=pass.com.tuespaciopilates.loyalty
APPLE_SIGNER_CERT_BASE64=
APPLE_SIGNER_KEY_BASE64=
APPLE_WWDR_CERT_BASE64=
# Solo si la llave privada quedó con contraseña (openssl sin -nodes):
APPLE_CERT_PASSWORD=
# Llave APNs .p8 (para actualizar pases ya instalados por push):
APPLE_KEY_ID=
APPLE_APNS_KEY_BASE64=
# CRÍTICO: fijar UNA sola vez (openssl rand -hex 32) y NUNCA cambiar. Si se deja
# vacío, se genera aleatorio por arranque e invalida los pases en cada redeploy.
APPLE_AUTH_TOKEN=

# ============================================================
# Google Wallet — pase de lealtad + sync server-side.
# ============================================================
GOOGLE_ISSUER_ID=
GOOGLE_SA_EMAIL=
# El private_key del JSON del service account (con los \n literales tal cual).
GOOGLE_SA_PRIVATE_KEY=
# Alternativa: el JSON completo de la key en base64 (en vez de EMAIL+PRIVATE_KEY).
GOOGLE_SA_KEY_JSON_BASE64=
